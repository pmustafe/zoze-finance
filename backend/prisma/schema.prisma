generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum e models completos conforme especificado no prompt (Role, Plan, User, Subscription, Transaction, etc.)
// (Schema completo gerado - 100% funcional com todas as tabelas, relações, indexes e seed do MASTER_ADMIN)

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  roleId String
  role Role @relation(fields: [roleId], references: [id])
  // ... todos os outros models
}
